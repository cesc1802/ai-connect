NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# LLM Provider API Keys (at least one required in production)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
MINIMAX_API_KEY=

# Auth (REQUIRED - min 32 chars for JWT_SECRET)
# Generate JWT_SECRET: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=1h

# Demo users JSON array (generate hash with: pnpm tsx scripts/hash-password.ts <password>)
# Example: [{"id":"user-1","username":"demo","passwordHash":"$2a$10$..."}]
DEMO_USERS=[]
